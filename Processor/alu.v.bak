module alu (
    input  [31:0] srca,      
    input  [31:0] srcb,      
    input  [3:0]  alucntrl,   
    output        zerosignal, 
    output reg [31:0] aluresult
);

    always @(*) begin
        case(alucntrl)
            4'b0000: aluresult = srca + srcb;                        // ADD
            4'b0001: aluresult = srca - srcb;                        // SUB
            4'b0010: aluresult = srca & srcb;                        // AND
            4'b0011: aluresult = srca | srcb;                        // OR
            4'b0100: aluresult = srca ^ srcb;                        // XOR
            4'b0101: aluresult = srca << srcb[4:0];                  // SLL (Shift Left Logical)
            4'b0110: aluresult = srca >> srcb[4:0];                  // SRL (Shift Right Logical)
            4'b0111: aluresult = $signed(srca) >>> srcb[4:0];        // SRA (Shift Right Arithmetic)
            4'b1000: aluresult = ($signed(srca) < $signed(srcb)) ? 32'd1 : 32'd0; // SLT (Signed Less Than)
            4'b1001: aluresult = (srca < srcb) ? 32'd1 : 32'd0;       // SLTU (Unsigned Less Than)
            4'b1010: aluresult = srcb;                               // Pass SrcB straight through
            default: aluresult = 32'b0;
        endcase
    end

    // Zero signal used for branching instructions (like BEQ)
    assign zerosignal = (aluresult == 32'd0) ? 1'b1 : 1'b0;

endmodule
