module ControlUnit(

    input [6:0] opcode,
    input [2:0] funct3,
    input [6:0] funct7,
    output reg RegWrite,
    output reg ALUSrc,
    
    output reg MemWrite,
    output reg [1:0] ResultSrc,

    output reg [2:0] ImmSrc,
    output reg [3:0] ALUControl,
    output reg Branch,
    output reg [2:0] BranchType,
    output reg Jump,
    output reg Jalr,
    output reg [1:0] StoreType,
    output reg [2:0] LoadType

);
always @(*) begin

    case(opcode)

        7'b0110011: //R type
        begin

            RegWrite  = 1'b1;

            ALUSrc    = 1'b0;
            
            MemWrite = 0;
            ResultSrc = 0;
            Branch = 0;
            Jump = 0;
            Jalr = 0;
            StoreType  = 2'b00;
            LoadType = 3'b000;

            //ImmSrc    = 2'b00;

            //ALUControl= 3'b000;
            case(funct3)
            3'b000:
            begin
            if(funct7 == 7'b0100000)
                ALUControl = 4'b0001; // SUB
            else
                ALUControl = 4'b0000; // ADD
            end
            3'b111:
            ALUControl = 4'b0010; // AND
            3'b110:
            ALUControl = 4'b0011; // OR
            3'b100:
            ALUControl = 4'b0100; // XOR
            
            3'b001:
            ALUControl = 4'b0101; // SLL

            3'b010:
            ALUControl = 4'b1000; // SLT

            3'b011:
            ALUControl = 4'b1001; // SLTU
            
            3'b101:
            begin
                if(funct7 == 7'b0100000)
                ALUControl = 4'b0111; // SRA
                else
                ALUControl = 4'b0110; // SRL
            end
            
            default:
            ALUControl = 4'b0000;

            endcase
        end


        7'b0010011: 
        begin

            RegWrite  = 1'b1;

            ALUSrc    = 1'b1;

            ImmSrc    = 3'b000;
            StoreType  = 2'b00;
            LoadType = 3'b000;

            //ALUControl= 3'b000;
            Branch = 0;
            MemWrite = 0;
            ResultSrc = 0;
            Jump = 0;
            Jalr = 0;
            
            case(funct3)

            3'b000:
            ALUControl = 4'b0000; // ADDI

            3'b111:
            ALUControl = 4'b0010; // ANDI

            3'b110:
            ALUControl = 4'b0011; // ORI

            3'b100:
            ALUControl = 4'b0100; // XORI

            3'b010:
            ALUControl = 4'b1000; // SLTI

            3'b011:
            ALUControl = 4'b1001; // SLTIU

            3'b001:
            ALUControl = 4'b0101; // SLLI

            3'b101:
            begin
            if(funct7 == 7'b0100000)
                ALUControl = 4'b0111; // SRAI
            else
                ALUControl = 4'b0110; // SRLI
            end

            default:
            ALUControl = 4'b0000;

            endcase
       
        end
        
        7'b0000011:
        begin
            RegWrite   = 1;

            ALUSrc     = 1;

            MemWrite   = 0;

            ResultSrc  = 1;
            
            Branch = 0;
            StoreType  = 2'b00;

            ImmSrc     = 3'b000; // I-Type

            ALUControl = 3'b000; // ADD
            
            Jump = 0;
            
            Jalr = 0;
            
            
            case(funct3)
                3'b000:
                LoadType = 3'b001; // LB
                3'b001:
                LoadType = 3'b010; // LH
                3'b010:
                LoadType = 3'b000; // LW
                3'b100:
                LoadType = 3'b011; // LBU
                3'b101:
                LoadType = 3'b100; // LHU
                default:
                LoadType = 3'b000;
            endcase
        end
        
        
        7'b0100011:
        begin
            RegWrite = 0;
            ALUSrc = 1;
            MemWrite = 1;
            ResultSrc = 2'b00;
            ImmSrc = 3'b001;
            ALUControl = 4'b0000;
            LoadType = 3'b000;
            case(funct3)
            3'b000:
            StoreType = 2'b01; // SB
            3'b001:
            StoreType = 2'b10; // SH
            3'b010:
            StoreType = 2'b00; // SW
            default:
            StoreType = 2'b00;
            endcase
        end
              
        7'b1100011:
        begin
            RegWrite = 0;
            ALUSrc   = 0;
            MemWrite = 0;
            ResultSrc= 0;
            Branch   = 1;
            Jump = 0;
            Jalr = 0;
            ImmSrc   = 3'b010;  // B-Type
            ALUControl = 3'b001; // SUB
            StoreType  = 2'b00;
            LoadType = 3'b000;
            
            case(funct3)
            3'b000:
            BranchType = 3'b000; // BEQ
            3'b001:
            BranchType = 3'b001; // BNE
            3'b100:
            BranchType = 3'b010; // BLT
            3'b101:
            BranchType = 3'b011; // BGE
            3'b110:
            BranchType = 3'b100; // BLTU
            3'b111:
            BranchType = 3'b101; // BGEU
            default:
            BranchType = 3'b000;
            endcase
        end
        
        
        7'b1101111:
        begin
            RegWrite = 1;
            ResultSrc = 2'b10; // PC+4
            ALUSrc = 0;
            MemWrite = 0;
            Branch = 0;
            ImmSrc = 3'b011;
            Jump = 1;
            Jalr = 0;
            StoreType  = 2'b00;
            LoadType = 3'b000;
        end
        
        7'b1100111:
        begin
            RegWrite = 1;
            ResultSrc = 2'b10; // PC+4
            ALUSrc = 1;
            MemWrite = 0;
            Jump = 1;
            Jalr = 1;
            ImmSrc = 3'b000; // I-Type
            ALUControl = 4'b0000; // ADD
            StoreType  = 2'b00;
            LoadType = 3'b000;
        end 
        
        7'b0010111:
        begin
            RegWrite  = 1;
            ALUSrc    = 0;
            MemWrite  = 0;
            ResultSrc = 2'b11; // PCImm
            Branch    = 0;
            Jump      = 0;
            Jalr      = 0;
            ImmSrc    = 3'b100; // U-Type
            ALUControl = 4'b0000;
            StoreType  = 2'b00;
            LoadType = 3'b000;
        end
        
        7'b0110111:
        begin
            RegWrite  = 1;
            ALUSrc    = 1;
            MemWrite  = 0;
            ResultSrc = 2'b00;
            Branch    = 0;
            Jump      = 0;
            Jalr      = 0;
            ImmSrc    = 3'b100; // U-Type
            ALUControl = 4'b1010; // ADD
            StoreType  = 2'b00;
            LoadType = 3'b000;
        end

        default: 
        begin

            RegWrite  = 1'b0;

            ALUSrc    = 1'b0;
            
            MemWrite = 0;
            ResultSrc = 0;

            ImmSrc    = 3'b000;

            ALUControl= 4'b0000;
            StoreType  = 2'b00;
            Branch = 0;
            LoadType = 3'b000;
        end

    endcase

end
endmodule