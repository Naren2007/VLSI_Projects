module DataMemory(
    input [31:0] A,
    input [31:0] WD,
    input WE,
    input clk,
    output reg [31:0] RD,
    input [1:0] StoreType,
    input [2:0] LoadType
);

reg [31:0] mem [0:255];


always @(posedge clk)
begin

    if(WE)
    begin

        case(StoreType)

            2'b00:
            begin
                // SW
                mem[A[31:2]] <= WD;
            end

            2'b01:
            begin
                // SB
                //mem[A[31:2]][7:0] <= WD[7:0];
                case(A[1:0])
                    2'b00:
                    mem[A[31:2]][7:0] <= WD[7:0];
                    2'b01:
                    mem[A[31:2]][15:8] <= WD[7:0];
                    2'b10:
                    mem[A[31:2]][23:16] <= WD[7:0];
                    2'b11:
                    mem[A[31:2]][31:24] <= WD[7:0];
                endcase
            end
            2'b10:
            begin
                // SH
                //mem[A[31:2]][15:0] <= WD[15:0];
                case(A[1])
                    1'b0:
                    mem[A[31:2]][15:0] <= WD[15:0];
                    1'b1:
                    mem[A[31:2]][31:16] <= WD[15:0];
                endcase
            end
            default:
            mem[A[31:2]] <= WD;
        endcase
    end
    
    
end


always @(*)
begin

    case(LoadType)

        3'b000:
            RD = mem[A[31:2]];

        3'b001:
        begin
            //RD = {{24{mem[A[31:2]][7]}}, mem[A[31:2]][7:0]};
            case(A[1:0])
            2'b00:
            RD = {{24{mem[A[31:2]][7]}},mem[A[31:2]][7:0]};

            2'b01:
            RD = {{24{mem[A[31:2]][15]}},mem[A[31:2]][15:8]};

            2'b10:
            RD = {{24{mem[A[31:2]][23]}},mem[A[31:2]][23:16]};

            2'b11:
            RD = {{24{mem[A[31:2]][31]}},mem[A[31:2]][31:24]};

        endcase           
        end

        3'b010:
        begin
            //RD = {{16{mem[A[31:2]][15]}},mem[A[31:2]][15:0]};
            case(A[1])
            1'b0:
            RD = {{16{mem[A[31:2]][15]}},mem[A[31:2]][15:0]};
            1'b1:
            RD = {{16{mem[A[31:2]][31]}},mem[A[31:2]][31:16]};
            endcase
        end

        3'b011:
        begin
            //RD = {24'b0,mem[A[31:2]][7:0]};
            case(A[1:0])
                2'b00:
                RD = {24'b0,mem[A[31:2]][7:0]};
                2'b01:
                RD = {24'b0,mem[A[31:2]][15:8]};
                2'b10:
                RD = {24'b0,mem[A[31:2]][23:16]};
                2'b11:
                RD = {24'b0,mem[A[31:2]][31:24]};
            endcase
        end

        3'b100:
            RD = {16'b0,
                  mem[A[31:2]][15:0]};

        default:
            RD = mem[A[31:2]];

    endcase

end

//assign RD = mem[A[31:2]];

endmodule